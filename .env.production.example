# Public edge configuration
PUBLIC_HOST=chat.example.com
ACME_EMAIL=ops@example.com

# Install/runtime mode hints
TLS_ENABLED=true
API_BASE=https://chat.example.com
WS_URL=wss://chat.example.com/ws

# Relay app
APP_ENV=production
LOG_LEVEL=info
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HEALTH_PATH=/health
READY_PATH=/ready
WS_PATH=/ws
API_PREFIX=/api/v1
# Single migration flow: relay-server applies migrations on startup.
RUN_MIGRATIONS_ON_START=true

# Database
POSTGRES_DB=secure_messenger
POSTGRES_USER=secure_messenger
POSTGRES_PASSWORD=replace_with_strong_password
DATABASE_URL=postgres://secure_messenger:replace_with_strong_password@postgres:5432/secure_messenger?sslmode=disable

# Security secrets (required)
AUTH_TOKEN_PEPPER=replace_with_very_long_random_pepper
SECURITY_ENCRYPTION_KEY=replace_with_base64_32_bytes

# Auth/session
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_HOURS=720
AUTH_2FA_CHALLENGE_TTL_MIN=5
AUTH_2FA_ISSUER=SecureMessenger

# Messaging/attachments
MESSAGING_ATTACHMENTS_DIR=/app/data/attachments
MESSAGING_ATTACHMENT_MAX_BYTES=20971520
MESSAGING_UNATTACHED_TTL_HOURS=24

# Social/profile media storage
# Preferred: S3-compatible backend (s3). Fallback: bounded local storage (local).
MEDIA_STORAGE_BACKEND=local
MEDIA_LOCAL_DIR=/app/data/media
MEDIA_LOCAL_MAX_TOTAL_BYTES=1073741824
MEDIA_LOCAL_MAX_PER_USER_BYTES=268435456
MEDIA_MAX_AVATAR_BYTES=5242880
MEDIA_MAX_BANNER_BYTES=10485760
MEDIA_MAX_PHOTO_BYTES=15728640
MEDIA_MAX_VIDEO_BYTES=52428800
MEDIA_STORY_TTL_HOURS=24
MEDIA_SOFT_DELETE_RETENTION_HOURS=72

# S3-compatible settings (used when MEDIA_STORAGE_BACKEND=s3)
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=
MEDIA_S3_ACCESS_KEY=
MEDIA_S3_SECRET_KEY=
MEDIA_S3_FORCE_PATH_STYLE=false
MEDIA_S3_PUBLIC_BASE_URL=

# Transport profile
TRANSPORT_PRIMARY_WS_ENDPOINT=wss://chat.example.com/ws
TRANSPORT_ALTERNATE_ENDPOINTS=https://chat.example.com/api/v1/sync/poll
TRANSPORT_WS_QUERY_TOKEN_FALLBACK=false
TRANSPORT_LONG_POLL_ENABLED=true
TRANSPORT_LONG_POLL_TIMEOUT_SEC=25
TRANSPORT_RECONNECT_BACKOFF_MIN_MS=500
TRANSPORT_RECONNECT_BACKOFF_MAX_MS=10000

# Browser/web security policy
# Comma-separated explicit allowlist for browser origins.
WEB_ALLOWED_ORIGINS=https://chat.example.com
# Keep tauri://localhost enabled to preserve desktop runtime compatibility.
WEB_ALLOW_TAURI_ORIGIN=true
# Production default should be false to avoid opaque/null browser origins.
WEB_ALLOW_NULL_ORIGIN=false
# Usually false in production; useful in local development only.
WEB_ALLOW_LOCALHOST_ORIGIN=false
WEB_ALLOW_LOCALHOST_SUBDOMAINS=false
# Trust X-Forwarded-* only behind your own reverse proxy.
WEB_TRUST_PROXY_HEADERS=true

# Browser session policy hints for /api/v1/config + /auth/web/*
WEB_SESSION_DEFAULT_PERSISTENCE=ephemeral
WEB_SESSION_ALLOW_REMEMBERED=true

# Server timeouts
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=10
HTTP_IDLE_TIMEOUT_SEC=60
HTTP_SHUTDOWN_TIMEOUT_SEC=10

# Host publish policy (used by docker-compose.ip.yml)
RELAY_PUBLISH_ADDRESS=0.0.0.0
RELAY_PUBLISH_PORT=8080
WEB_PUBLISH_ADDRESS=0.0.0.0
WEB_PUBLISH_PORT=80
