APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HEALTH_PATH=/health
READY_PATH=/ready
WS_PATH=/ws
API_PREFIX=/api/v1
LOG_LEVEL=debug
RUN_MIGRATIONS_ON_START=true
DATABASE_URL=postgres://postgres:postgres@postgres:5432/secure_messenger?sslmode=disable
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=10
HTTP_IDLE_TIMEOUT_SEC=60
HTTP_SHUTDOWN_TIMEOUT_SEC=10
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_HOURS=720
AUTH_2FA_CHALLENGE_TTL_MIN=5
AUTH_2FA_ISSUER=SecureMessenger
AUTH_TOKEN_PEPPER=dev-compose-token-pepper
SECURITY_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
MESSAGING_ATTACHMENTS_DIR=./data/attachments
MESSAGING_ATTACHMENT_MAX_BYTES=20971520
MESSAGING_UNATTACHED_TTL_HOURS=24
TRANSPORT_PRIMARY_WS_ENDPOINT=ws://localhost:8080/ws
TRANSPORT_ALTERNATE_ENDPOINTS=http://localhost:8080/api/v1/sync/poll
TRANSPORT_WS_QUERY_TOKEN_FALLBACK=true
TRANSPORT_LONG_POLL_ENABLED=true
TRANSPORT_LONG_POLL_TIMEOUT_SEC=25
TRANSPORT_RECONNECT_BACKOFF_MIN_MS=500
TRANSPORT_RECONNECT_BACKOFF_MAX_MS=10000
