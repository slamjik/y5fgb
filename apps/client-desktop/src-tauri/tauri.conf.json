{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secure Messenger",
  "version": "1.0.0-rc.3",
  "identifier": "com.example.securemessenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Secure Messenger",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https: wss: http: ws:; frame-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none';"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "appimage", "deb"],
    "publisher": "Secure Messenger Team",
    "homepage": "https://github.com/example/secure-messenger",
    "category": "SocialNetworking",
    "shortDescription": "Secure desktop-first messenger with resilient transport fallback.",
    "longDescription": "Secure Messenger is a desktop-first secure messaging client with device trust, encrypted envelopes, and resilient transport fallback for unstable networks.",
    "copyright": "Copyright (c) 2026 Secure Messenger contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/example/secure-messenger/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExRTRGQzI3MDBGQkI1RTEKUldUaHRmc0FKL3prb1RuSmRYQkVRNU52cTNONDR2bFIzWXBUK3crUjl5VnZGS2l5eEVHNUI1MmwK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
